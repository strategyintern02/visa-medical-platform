# Visa Medical Platform — environment variables
#
# LOCAL DEV: leave these unset. The server falls back to reading data/data.json
#            from disk, so the app runs with no configuration.
#
# PRODUCTION (Vercel): set BOTH so the server reads/writes the live data Gist.
#   Project Settings -> Environment Variables.

# ID of the private GitHub Gist that holds data.json (+ data-snapshot.json).
GIST_ID=

# Fine-grained GitHub Personal Access Token with gist read/write scope.
GITHUB_TOKEN=

# Optional: override the local port (defaults to 3000).
# PORT=3000
